# =====================================================================
# Home School HQ — CEO / Operations Portal v1 — environment
# Copy to .env.local (local dev) or set in Vercel Project Settings.
# =====================================================================

# --- Supabase project (ref: qdktunotolpgqszvbvwj) -------------------
# The URL and the PUBLISHABLE (anon) key are safe in the browser — they
# are used only for the Supabase Auth login. They grant NOTHING on the
# homeschool schema (no anon grants), so they cannot read learner data.
NEXT_PUBLIC_SUPABASE_URL=https://qdktunotolpgqszvbvwj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# --- SERVER ONLY — never ship to the browser ------------------------
# The service_role key bypasses RLS. It is read ONLY in server route
# handlers / server components. Do NOT prefix it with NEXT_PUBLIC.
# Keep it out of shared chats and repos (Security handover).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated allowlist of admin emails. A logged-in user is only
# treated as admin if their email is here OR their homeschool.profiles
# row has role='admin'. Dominic's login goes here.
ADMIN_EMAILS=pullenmarketing@gmail.com

# --- Kids' portal session -------------------------------------------
# Secret used to sign the boys' PIN-session cookie (HMAC). Optional: if
# unset, the app falls back to the service_role key. Set any long random
# string for a dedicated secret. Server-only; never NEXT_PUBLIC.
KID_SESSION_SECRET=

# --- Demo mode ------------------------------------------------------
# Set to 1 to run the portal with mock data and NO login (for visual
# review / Vercel preview before the live auth+RLS+exposure gate is
# closed). MUST be unset/0 for any real data. If the Supabase vars
# above are missing, the app falls back to demo mode automatically.
PORTAL_DEMO=1
